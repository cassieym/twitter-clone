<div class="border-b border-zinc-800 p-4">
  <h1 class="text-xl font-bold">Edit profile</h1>
</div>

<div class="p-4">
  <%= form_with model: @user, url: user_path(@user), method: :patch do |f| %>
    <div class="mb-4">
      <%= f.label :display_name, class: "block text-sm text-zinc-400 mb-1" %>
      <%= f.text_field :display_name,
          class: "w-full bg-zinc-900 border border-zinc-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-sky-500",
          maxlength: 50 %>
    </div>

    <div class="mb-4">
      <%= f.label :bio, class: "block text-sm text-zinc-400 mb-1" %>
      <%= f.text_area :bio,
          class: "w-full bg-zinc-900 border border-zinc-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-sky-500 resize-none",
          rows: 3, maxlength: 160 %>
    </div>

    <div class="mb-6">
      <%= f.label :avatar, class: "block text-sm text-zinc-400 mb-1" %>
      <%= f.file_field :avatar, class: "text-sm text-zinc-400" %>
    </div>

    <%= f.submit "Save", class: "bg-white text-black font-bold px-5 py-2 rounded-full hover:bg-zinc-200 transition-colors cursor-pointer" %>
  <% end %>
</div>
