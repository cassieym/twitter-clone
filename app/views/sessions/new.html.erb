<div class="p-6 max-w-md mx-auto">
  <h1 class="text-2xl font-bold mb-6">Sign in to Twitter Clone</h1>

  <% if flash[:alert] %>
    <div class="mb-4 p-3 bg-red-900 border border-red-700 rounded-lg text-sm">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: session_path do |f| %>
    <div class="mb-4">
      <%= f.label :email_address, "Email", class: "block text-sm text-zinc-400 mb-1" %>
      <%= f.email_field :email_address,
          required: true,
          autofocus: true,
          autocomplete: "username",
          value: params[:email_address],
          class: "w-full bg-zinc-900 border border-zinc-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-sky-500" %>
    </div>

    <div class="mb-6">
      <%= f.label :password, class: "block text-sm text-zinc-400 mb-1" %>
      <%= f.password_field :password,
          required: true,
          autocomplete: "current-password",
          maxlength: 72,
          class: "w-full bg-zinc-900 border border-zinc-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-sky-500" %>
    </div>

    <%= f.submit "Sign in", class: "w-full bg-sky-500 hover:bg-sky-400 text-white font-bold py-2 px-4 rounded-full cursor-pointer transition-colors" %>
  <% end %>

  <p class="mt-4 text-zinc-500 text-sm">
    <%= link_to "Forgot password?", new_password_path, class: "text-sky-400 hover:underline" %>
  </p>

  <p class="mt-2 text-zinc-500 text-sm">
    Don't have an account?
    <%= link_to "Sign up", new_registration_path, class: "text-sky-400 hover:underline" %>
  </p>
</div>