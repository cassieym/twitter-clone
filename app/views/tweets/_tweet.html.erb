<article id="tweet-<%= tweet.id %>" class="border-b border-zinc-800 p-4 flex gap-3 hover:bg-zinc-900/50 transition-colors">
  <div class="shrink-0">
    <div class="w-10 h-10 rounded-full bg-zinc-700 flex items-center justify-center text-sm font-bold">
      <%= tweet.user.display_name&.first&.upcase || tweet.user.username.first.upcase %>
    </div>
  </div>

  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-1 flex-wrap">
      <%= link_to user_path(tweet.user), class: "font-bold hover:underline" do %>
        <%= tweet.user.display_name.presence || "@#{tweet.user.username}" %>
      <% end %>
      <span class="text-zinc-500 text-sm">@<%= tweet.user.username %></span>
      <span class="text-zinc-500 text-sm">·</span>
      <span class="text-zinc-500 text-sm"><%= time_ago_in_words(tweet.created_at) %> ago</span>
    </div>

    <% if tweet.parent %>
      <p class="text-zinc-500 text-sm">
        Replying to <%= link_to "@#{tweet.parent.user.username}", user_path(tweet.parent.user), class: "text-sky-400 hover:underline" %>
      </p>
    <% end %>

    <p class="mt-1 break-words"><%= tweet.body %></p>

    <div class="flex items-center gap-6 mt-3 text-zinc-500 text-sm">
      <%= link_to tweet_path(tweet), class: "flex items-center gap-1.5 hover:text-sky-400 transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <span><%= tweet.replies_count %></span>
      <% end %>

      <%= render "tweets/like_button", tweet: tweet %>

      <% if tweet.user == Current.user %>
        <%= button_to tweet_path(tweet), method: :delete,
            data: { turbo_confirm: "Delete this tweet?" },
            class: "flex items-center gap-1.5 hover:text-red-400 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        <% end %>
      <% end %>
    </div>
  </div>
</article>
