<div class="p-6 max-w-md mx-auto">
  <h1 class="text-2xl font-bold mb-6">Create your account</h1>

  <%= form_with model: @user, url: registration_path do |f| %>
    <% if @user.errors.any? %>
      <div class="mb-4 p-3 bg-red-900 border border-red-700 rounded-lg text-sm">
        <% @user.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :email_address, "Email", class: "block text-sm text-zinc-400 mb-1" %>
      <%= f.email_field :email_address, class: "w-full bg-zinc-900 border border-zinc-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-sky-500", required: true, autofocus: true %>
    </div>

    <div class="mb-4">
      <%= f.label :username, "@Username", class: "block text-sm text-zinc-400 mb-1" %>
      <%= f.text_field :username, class: "w-full bg-zinc-900 border border-zinc-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-sky-500", required: true %>
    </div>

    <div class="mb-4">
      <%= f.label :display_name, "Display Name", class: "block text-sm text-zinc-400 mb-1" %>
      <%= f.text_field :display_name, class: "w-full bg-zinc-900 border border-zinc-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-sky-500" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "block text-sm text-zinc-400 mb-1" %>
      <%= f.password_field :password, class: "w-full bg-zinc-900 border border-zinc-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-sky-500", required: true %>
    </div>

    <div class="mb-6">
      <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm text-zinc-400 mb-1" %>
      <%= f.password_field :password_confirmation, class: "w-full bg-zinc-900 border border-zinc-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-sky-500", required: true %>
    </div>

    <%= f.submit "Sign up", class: "w-full bg-sky-500 hover:bg-sky-400 text-white font-bold py-2 px-4 rounded-full cursor-pointer transition-colors" %>
  <% end %>

  <p class="mt-4 text-zinc-500 text-sm">
    Already have an account?
    <%= link_to "Log in", new_session_path, class: "text-sky-400 hover:underline" %>
  </p>
</div>